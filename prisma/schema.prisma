generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WhatsAppHealth {
  ACTIVE
  WARNING
  LIMITED
  BANNED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  AI_RECOMMENDATION
  WHATSAPP_WARNING
  WHATSAPP_BAN
  CALENDAR_REMINDER
  ADMIN_REMARK
}

model User {
  id              String           @id @default(cuid())
  fullName        String
  email           String           @unique
  passwordHash    String
  role            Role             @default(USER)
  status          UserStatus       @default(ACTIVE)
  avatarUrl       String?
  teamName        String?
  lastLoginAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  activities      Activity[]
  assignedTasks   MarketingTask[]  @relation("AssignedTasks")
  createdTasks    MarketingTask[]  @relation("CreatedTasks")
  calendarEvents  CalendarEvent[]  @relation("AssignedEvents")
  createdEvents   CalendarEvent[]  @relation("CreatedEvents")
  receivedRemarks Remark[]         @relation("ReceivedRemarks")
  createdRemarks  Remark[]         @relation("CreatedRemarks")
  aiProgress      AIProgress[]
  whatsAppAccounts WhatsAppAccount[]
  notifications   Notification[]
  reports         Report[]         @relation("ReportOwner")
  generatedReports Report[]        @relation("ReportGenerator")
  auditLogs       AuditLog[]
  teamMemberships TeamMember[]
  chatMessages    ChatMessage[]
  activityLogs    ActivityLog[]

  @@index([role, status])
  @@index([createdAt])
}

model Activity {
  id                    String   @id @default(cuid())
  userId                String
  date                  DateTime @default(now())
  dailyMessagesSent     Int      @default(0)
  monthlyMessagesSent   Int      @default(0)
  successfulReplies     Int      @default(0)
  failedReplies         Int      @default(0)
  pendingFollowUps      Int      @default(0)
  completedFollowUps    Int      @default(0)
  dailyTarget           Int      @default(100)
  monthlyTarget         Int      @default(2200)
  successRate           Float    @default(0)
  productivity          Float    @default(0)
  performanceScore      Float    @default(0)
  completionPercentage  Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
}

model ActivityLog {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date               DateTime         @db.Date
  messageCount       Int              @default(0)
  remarks            String?
  aiProgress         String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  whatsAppAccountId  String?
  whatsAppAccount    WhatsAppAccount? @relation(fields: [whatsAppAccountId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([userId])
  @@index([whatsAppAccountId])
}

model Team {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  members     TeamMember[]
  tasks       MarketingTask[]

  @@index([name])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
}

enum TaskAssignmentType {
  INDIVIDUAL
  TEAM
  ALL_USERS
}

model MarketingTask {
  id                 String             @id @default(cuid())
  title              String
  description        String?
  status             TaskStatus         @default(TODO)
  priority           Priority           @default(MEDIUM)
  category           String?
  dueDate            DateTime?
  completedAt        DateTime?
  assignmentType     TaskAssignmentType @default(INDIVIDUAL)
  assignedToId       String?
  assignedToTeamId   String?
  createdById        String
  remarks            String?
  attachments        String[]
  submissionNote     String?
  submittedAt        DateTime?
  submittedFiles     String[]
  notificationSent   Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  assignedTo         User?              @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToTeam     Team?              @relation(fields: [assignedToTeamId], references: [id], onDelete: SetNull)
  createdBy          User               @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)
  progressUpdates    TaskProgress[]

  @@index([assignedToId, status])
  @@index([assignedToTeamId])
  @@index([createdById])
  @@index([dueDate])
  @@index([assignmentType])
}

model TaskProgress {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  status    TaskStatus
  progress  Int      @default(0)
  comment   String?
  createdAt DateTime @default(now())
  task      MarketingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model CalendarEvent {
  id           String   @id @default(cuid())
  title        String
  description  String?
  startAt      DateTime
  endAt        DateTime
  isAllDay     Boolean  @default(false)
  assignedToId String?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  assignedTo   User?    @relation("AssignedEvents", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User     @relation("CreatedEvents", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([startAt, endAt])
  @@index([assignedToId])
}

model Remark {
  id          String   @id @default(cuid())
  content     String
  userId      String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("ReceivedRemarks", fields: [userId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("CreatedRemarks", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdById])
}

model AIProgress {
  id                    String   @id @default(cuid())
  userId                String
  period                String
  summary               String
  productivityScore     Float    @default(0)
  aiScore               Float    @default(0)
  bestSendTime          String?
  suggestedFollowUps    String[]
  improvementTips       String[]
  riskAlerts            String[]
  inactiveUserSignal    Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, period])
}

model WhatsAppAccount {
  id              String         @id @default(cuid())
  userId          String
  phoneNumber     String         @unique
  label           String?
  status          WhatsAppHealth @default(ACTIVE)
  healthScore     Int            @default(100)
  lastCheckedAt   DateTime       @default(now())
  lastActivityAt  DateTime?
  dailyMessages   Int            @default(0)
  monthlyMessages Int            @default(0)
  warningHistory  Json?
  banHistory      Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityLogs    ActivityLog[]

  @@index([userId])
  @@index([status])
  @@index([healthScore])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
}

model Report {
  id            String   @id @default(cuid())
  userId        String
  generatedById String?
  period        String
  startDate     DateTime
  endDate       DateTime
  payload       Json
  createdAt     DateTime @default(now())
  user          User     @relation("ReportOwner", fields: [userId], references: [id], onDelete: Cascade)
  generatedBy   User?    @relation("ReportGenerator", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([userId, period])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum ChatStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

model ChatMessage {
  id          String     @id @default(cuid())
  userId      String
  content     String
  recipient   String
  channel     String     @default("WhatsApp")
  status      ChatStatus @default(SENT)
  sentAt      DateTime   @default(now())
  deliveredAt DateTime?
  readAt      DateTime?
  repliedAt   DateTime?
  hasReply    Boolean    @default(false)
  replyContent String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([sentAt])
  @@index([channel])
}
